<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════
         SemaBuzz Obsidian Theme — Colors & Brushes
         ═══════════════════════════════════════════════ -->

    <!-- Core palette -->
    <Color x:Key="ObsidianColor">#FF121212</Color>
    <Color x:Key="ObsidianSurfaceColor">#FF1E1E1E</Color>
    <Color x:Key="ObsidianBorderColor">#FF2A2A2A</Color>
    <Color x:Key="AmberColor">#FFFFB300</Color>
    <Color x:Key="AmberDimColor">#80FFB300</Color>
    <Color x:Key="AmberGlowColor">#33FFB300</Color>
    <Color x:Key="CrtGreenColor">#FF00FF41</Color>
    <Color x:Key="WireDeadColor">#FF444444</Color>
    <Color x:Key="WireSecuredColor">#FF00FF41</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="ObsidianBrush"        Color="{StaticResource ObsidianColor}"/>
    <SolidColorBrush x:Key="ObsidianSurfaceBrush" Color="{StaticResource ObsidianSurfaceColor}"/>
    <SolidColorBrush x:Key="ObsidianBorderBrush"  Color="{StaticResource ObsidianBorderColor}"/>
    <SolidColorBrush x:Key="AmberBrush"            Color="{StaticResource AmberColor}"/>
    <SolidColorBrush x:Key="AmberDimBrush"         Color="{StaticResource AmberDimColor}"/>
    <SolidColorBrush x:Key="AmberGlowBrush"        Color="{StaticResource AmberGlowColor}"/>
    <SolidColorBrush x:Key="CrtGreenBrush"         Color="{StaticResource CrtGreenColor}"/>
    <SolidColorBrush x:Key="WireDeadBrush"         Color="{StaticResource WireDeadColor}"/>
    <SolidColorBrush x:Key="WireSecuredBrush"      Color="{StaticResource WireSecuredColor}"/>

    <!-- Glow gradient for the BuzzIndicator -->
    <LinearGradientBrush x:Key="AmberGlowGradient" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#00FFB300" Offset="0"/>
        <GradientStop Color="#FFFFB300" Offset="0.5"/>
        <GradientStop Color="#00FFB300" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
