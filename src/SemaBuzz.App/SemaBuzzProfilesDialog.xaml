<Window x:Class="SemaBuzz.App.SemaBuzzProfilesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz — Profiles"
        Height="480" Width="460"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Border BorderBrush="{DynamicResource WindowHeaderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowHeaderBrush}"
              MouseLeftButtonDown="Header_MouseDown">
            <TextBlock Text="PROFILES"
                       VerticalAlignment="Center" Margin="20 0"
                       Foreground="{DynamicResource AmberHeaderBrush}"
                       FontWeight="Bold" FontSize="13"/>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0 0 6 0">
        <StackPanel Margin="28 20">

        <TextBlock Text="Select the identity that will be used when you start or join a Buzz. Profiles cannot be edited or deleted while a Buzz is active."
                   Foreground="#9E9E9E" FontSize="10" TextWrapping="Wrap"
                   Margin="0 0 0 15"/>

        <TextBlock x:Name="ActiveWireNotice"
                   Text="⚠ Profiles cannot be edited or deleted while a Buzz is active."
                   Foreground="#A0804000" FontSize="10" TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Margin="0 0 0 15"/>

        <!-- Profile rows populated in code -->
        <StackPanel x:Name="ProfileItemsPanel" Margin="0 0 0 10"/>

        <!-- Add / Edit buttons -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 4">
            <Button x:Name="EditProfileBtn"
                    Style="{StaticResource SemaBuzzButton}"
                    Content="EDIT"
                    IsEnabled="False"
                    Click="EditProfile_Click"
                    Margin="0 0 8 0"/>
            <Button Style="{StaticResource SemaBuzzButton}"
                    Content="+ ADD"
                    Click="AddProfile_Click"/>
        </StackPanel>

        <!-- Inline profile editor (hidden until add or edit is clicked) -->
        <Border x:Name="ProfileEditorPanel"
                Visibility="Collapsed"
                Background="{DynamicResource ObsidianSurfaceBrush}"
                BorderBrush="{DynamicResource ObsidianBorderBrush}"
                BorderThickness="1"
                Padding="14 12"
                Margin="0 12 0 0">
            <StackPanel>
                <TextBlock Text="Handle *" Foreground="#9E9E9E" FontSize="11" Margin="0 0 0 4"/>
                <TextBox x:Name="ProfileHandleBox"
                         Style="{StaticResource SemaBuzzInput}"
                         MaxLength="32"
                         Margin="0 0 0 4"
                         TextChanged="ProfileHandleBox_TextChanged"/>
                <TextBlock x:Name="HandleErrorText"
                           Text="A handle is required."
                           Foreground="#FF5252" FontSize="10"
                           Visibility="Collapsed"
                           Margin="0 0 0 8"/>
                <TextBlock Text="Avatar (optional)" Foreground="#9E9E9E" FontSize="11" Margin="0 0 0 6"/>
                <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                    <Ellipse x:Name="ProfileAvatarPreview"
                             Width="44" Height="44"
                             Fill="{DynamicResource ObsidianBrush}"
                             Stroke="{DynamicResource ObsidianBorderBrush}"
                             StrokeThickness="1"
                             Margin="0 0 10 0"/>
                    <StackPanel VerticalAlignment="Center">
                        <Button Style="{StaticResource SemaBuzzButton}"
                                Content="CHOOSE IMAGE"
                                Click="ProfileChooseAvatar_Click"/>
                        <Button x:Name="ProfileClearAvatarBtn"
                                Style="{StaticResource SemaBuzzButton}"
                                Content="CLEAR"
                                IsEnabled="False"
                                Click="ProfileClearAvatar_Click"
                                Margin="0 4 0 0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource SemaBuzzButton}" Content="SAVE"
                            Click="ProfileSave_Click" Margin="0 0 8 0"/>
                    <Button Style="{StaticResource SemaBuzzButton}" Content="CANCEL"
                            Click="ProfileEditorCancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        </StackPanel>
        </ScrollViewer>

        <!-- Separator -->
        <Rectangle Grid.Row="3" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="20 0">
            <Button Style="{StaticResource SemaBuzzButton}" Content="CLOSE"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Click="Close_Click"/>
        </Grid>

    </Grid>
    </Border>
</Window>
