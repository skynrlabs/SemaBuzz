<Window x:Class="SemaBuzz.App.SemaBuzzConnectRequestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz — Incoming Connection"
        Height="480" Width="440"
        Background="{DynamicResource WindowBackgroundBrush}" Foreground="{DynamicResource AmberBrush}"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Border BorderBrush="{DynamicResource AmberDimBrush}" BorderThickness="1">
    <StackPanel Margin="24 20">

        <TextBlock Text="› incoming connection request"
                   Foreground="#9E9E9E" FontSize="11"
                   Margin="0 0 0 6"/>

        <TextBlock x:Name="FromLabel"
                   Foreground="{DynamicResource AmberBrush}" Margin="0 0 0 4" TextWrapping="Wrap"/>

        <TextBlock Text="Accept this connection and open the wire?"
                   Foreground="#9E9E9E" FontSize="11"
                   Margin="0 0 0 4"/>

        <TextBlock x:Name="CountdownLabel"
                   Foreground="#9E9E9E" FontSize="11"
                   Margin="0 0 0 20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource SemaBuzzButton}" Content="DECLINE"
                    Margin="0 0 8 0" Click="Decline_Click"/>
            <Button Style="{StaticResource SemaBuzzButton}" Content="ACCEPT"
                    Click="Accept_Click"/>
        </StackPanel>

    </StackPanel>
    </Border>
</Window>
