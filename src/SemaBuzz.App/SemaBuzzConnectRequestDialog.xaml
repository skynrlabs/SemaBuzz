<Window x:Class="SemaBuzz.App.SemaBuzzConnectRequestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz — Incoming Connection"
        Height="200" Width="440"
        Background="#121212" Foreground="#FFB300"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <StackPanel Margin="24 20">

        <TextBlock Text="» incoming connection request"
                   Foreground="#666666" FontSize="11" FontStyle="Italic"
                   Margin="0 0 0 6"/>

        <TextBlock x:Name="FromLabel"
                   Foreground="#FFB300" Margin="0 0 0 4" TextWrapping="Wrap"/>

        <TextBlock Text="Accept this connection and open the wire?"
                   Foreground="#AAAAAA" FontSize="11"
                   Margin="0 0 0 4"/>

        <TextBlock x:Name="CountdownLabel"
                   Foreground="#555555" FontSize="11" FontStyle="Italic"
                   Margin="0 0 0 20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource SemaBuzzButton}" Content="DECLINE"
                    Margin="0 0 8 0" Click="Decline_Click"/>
            <Button Style="{StaticResource SemaBuzzButton}" Content="ACCEPT"
                    Click="Accept_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
