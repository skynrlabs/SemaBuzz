<Window x:Class="SemaBuzz.App.SemaBuzzInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="190" Width="420"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource AmberBrush}"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Border BorderBrush="{DynamicResource WindowHeaderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowHeaderBrush}"
              MouseLeftButtonDown="Header_MouseDown">
            <TextBlock x:Name="TitleLabel"
                       VerticalAlignment="Center" Margin="20 0"
                       Foreground="{DynamicResource AmberHeaderBrush}"
                       FontWeight="Bold" FontSize="13"/>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Body -->
        <StackPanel Grid.Row="2" Margin="28 18 28 0" VerticalAlignment="Top">
            <TextBlock x:Name="PromptLabel"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource WireDeadBrush}"
                       Margin="0 0 0 6"/>
            <TextBox x:Name="InputBox"
                     Style="{StaticResource SemaBuzzInput}"
                     MaxLength="80"
                     KeyDown="InputBox_KeyDown"/>
        </StackPanel>

        <!-- Separator -->
        <Rectangle Grid.Row="3" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Footer -->
        <Grid Grid.Row="4" Background="{DynamicResource ObsidianSurfaceBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 20 0"
                        VerticalAlignment="Center">
                <Button Content="CANCEL"
                        Style="{StaticResource SemaBuzzButton}"
                        Margin="0 0 10 0"
                        Click="Cancel_Click"/>
                <Button Content="OK"
                        Style="{StaticResource SemaBuzzButton}"
                        Click="Ok_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
    </Border>
</Window>
