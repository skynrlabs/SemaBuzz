<Window x:Class="SemaBuzz.App.SemaBuzzAboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz — About"
        Height="480" Width="460"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource AmberBrush}"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Border BorderBrush="{DynamicResource WindowHeaderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowHeaderBrush}"
              MouseLeftButtonDown="Header_MouseDown">
            <TextBlock Text="ABOUT"
                       VerticalAlignment="Center" Margin="20 0"
                       Foreground="{DynamicResource AmberHeaderBrush}"
                       FontWeight="Bold" FontSize="13"/>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Content -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" Margin="28 0">

            <!-- Logo -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 6">
                <TextBlock Text="SEMA" Foreground="{DynamicResource AmberBrush}" FontWeight="Bold"  FontSize="28"/>
                <TextBlock Text="BUZZ" Foreground="{DynamicResource AmberBrush}" FontWeight="Light" FontSize="28"/>
            </StackPanel>

            <TextBlock Text="Every pause. Every word. Live."
                       Foreground="#9E9E9E"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 4"/>

            <TextBlock x:Name="VersionLabel"
                       Foreground="#9E9E9E"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>

            <!-- Website button -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 28">
            <Button Style="{StaticResource SemaBuzzButton}"
                    Click="Website_Click">
                <StackPanel Orientation="Horizontal">
                    <!-- Globe icon -->
                    <Viewbox Width="14" Height="14" Margin="0 0 7 0" VerticalAlignment="Center">
                        <Path Fill="{DynamicResource AmberBrush}"
                              Data="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0zM1.1 8.7h2c.1 1.2.4 2.3.8 3.2
                                    -1.3-.7-2.3-1.8-2.8-3.2zm2 -1.4h-2c.5-1.4 1.5-2.5 2.8-3.2-.4.9-.7 2-.8 3.2z
                                    M7.3 1.1c-.7.6-1.4 1.9-1.7 3.5H7.3V1.1zm0 4.9H5.5c-.1 1-.1 2 0 2.9H7.3V6z
                                    M7.3 9.4H5.6c.3 1.6 1 2.9 1.7 3.5V9.4zm1.4 3.5c.7-.6 1.4-1.9 1.7-3.5H8.7v3.5z
                                    M8.7 9.4V6H10c.1 1 .1 2 0 2.9H8.7zM8.7 4.6V1.1c.7.6 1.4 1.9 1.7 3.5H8.7z
                                    M11.1 7.3H13c-.1-1.2-.4-2.3-.8-3.2 1.3.7 2.3 1.8 2.8 3.2h-2z
                                    M13 8.7h-1.9c-.1 1.2-.4 2.3-.8 3.2 1.3-.7 2.3-1.8 2.7-3.2z"
                              Stretch="Uniform"/>
                    </Viewbox>
                    <TextBlock Text="SemaBuzz.me" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            </StackPanel>

            <!-- Divider -->
            <Rectangle Height="1" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 0 0 20"/>

            <!-- Copyright section -->
            <TextBlock Text="COPYRIGHT"
                       Foreground="{DynamicResource AmberBrush}"
                       FontWeight="Bold" FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 10"/>

            <TextBlock Text="Copyright &#169; 2026 Skynr Labs. All rights reserved."
                       Foreground="#9E9E9E" FontSize="10"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0 0 0 8"/>

            <TextBlock Text="The SemaBuzz relay server is proprietary software. All rights reserved by Skynr Labs."
                       Foreground="#6E6E6E" FontSize="10"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0 0 0 0"/>

        </StackPanel>

        <!-- Separator -->
        <Rectangle Grid.Row="3" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="20 0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button Style="{StaticResource SemaBuzzButton}"
                        Content="Privacy"
                        VerticalAlignment="Center"
                        Margin="0 0 8 0"
                        Click="Privacy_Click"/>
                <Button Style="{StaticResource SemaBuzzButton}"
                        Content="Terms"
                        VerticalAlignment="Center"
                        Click="Terms_Click"/>
            </StackPanel>
            <Button Style="{StaticResource SemaBuzzButton}" Content="CLOSE"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Click="Close_Click"/>
        </Grid>

    </Grid>
    </Border>
</Window>
