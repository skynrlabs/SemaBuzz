<Window x:Class="SemaBuzz.App.SemaBuzzAboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz — About"
        Height="560" Width="420"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource AmberBrush}"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowHeaderBrush}"
              MouseLeftButtonDown="Header_MouseDown">
            <TextBlock Text="ABOUT"
                       VerticalAlignment="Center" Margin="20 0"
                       FontWeight="Bold" FontSize="13"/>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Content -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="28 0">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 6">
                <TextBlock Text="SEMA" Foreground="{DynamicResource AmberBrush}" FontWeight="Bold"  FontSize="28"/>
                <TextBlock Text="BUZZ" Foreground="{DynamicResource AmberBrush}" FontWeight="Light" FontSize="28"/>
            </StackPanel>

            <TextBlock Text="Direct. Private. Personal."
                       Foreground="#666"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>

            <TextBlock x:Name="VersionLabel"
                       Foreground="#555"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 6"/>

            <TextBlock Text="© 2026 Skynr Labs · MIT License"
                       Foreground="#444"
                       FontSize="10"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 16"/>

            <Button Style="{StaticResource SemaBuzzButton}"
                    Content="semabuzz.me"
                    HorizontalAlignment="Center"
                    Click="Website_Click"/>

        </StackPanel>

        <!-- Separator -->
        <Rectangle Grid.Row="3" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="20 0">
            <Button Style="{StaticResource SemaBuzzButton}" Content="CLOSE"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Click="Close_Click"/>
        </Grid>

    </Grid>
</Window>
