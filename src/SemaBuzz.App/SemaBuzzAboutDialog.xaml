<Window x:Class="SemaBuzz.App.SemaBuzzAboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz — About"
        Height="480" Width="460"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource AmberBrush}"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Border BorderBrush="{DynamicResource AmberDimBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowHeaderBrush}"
              MouseLeftButtonDown="Header_MouseDown">
            <TextBlock Text="ABOUT"
                       VerticalAlignment="Center" Margin="20 0"
                       FontWeight="Bold" FontSize="13"/>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Content -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" Margin="28 0">

            <!-- Logo -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 6">
                <TextBlock Text="SEMA" Foreground="{DynamicResource AmberBrush}" FontWeight="Bold"  FontSize="28"/>
                <TextBlock Text="BUZZ" Foreground="{DynamicResource AmberBrush}" FontWeight="Light" FontSize="28"/>
            </StackPanel>

            <TextBlock Text="Every pause. Every word. Live."
                       Foreground="#9E9E9E"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 4"/>

            <TextBlock x:Name="VersionLabel"
                       Foreground="#9E9E9E"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>

            <!-- GitHub + Website buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 28">
            <Button Style="{StaticResource SemaBuzzButton}"
                    Margin="0 0 10 0"
                    Click="GitHub_Click">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="14" Height="14" Margin="0 0 7 0" VerticalAlignment="Center">
                        <Path Fill="{DynamicResource AmberBrush}"
                              Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
                                    0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
                                    -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
                                    .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15
                                    -.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09
                                    2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82
                                    2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01
                                    2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
                              Stretch="Uniform"/>
                    </Viewbox>
                    <TextBlock Text="GitHub" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource SemaBuzzButton}"
                    Click="Website_Click">
                <StackPanel Orientation="Horizontal">
                    <!-- Globe icon -->
                    <Viewbox Width="14" Height="14" Margin="0 0 7 0" VerticalAlignment="Center">
                        <Path Fill="{DynamicResource AmberBrush}"
                              Data="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0zM1.1 8.7h2c.1 1.2.4 2.3.8 3.2
                                    -1.3-.7-2.3-1.8-2.8-3.2zm2 -1.4h-2c.5-1.4 1.5-2.5 2.8-3.2-.4.9-.7 2-.8 3.2z
                                    M7.3 1.1c-.7.6-1.4 1.9-1.7 3.5H7.3V1.1zm0 4.9H5.5c-.1 1-.1 2 0 2.9H7.3V6z
                                    M7.3 9.4H5.6c.3 1.6 1 2.9 1.7 3.5V9.4zm1.4 3.5c.7-.6 1.4-1.9 1.7-3.5H8.7v3.5z
                                    M8.7 9.4V6H10c.1 1 .1 2 0 2.9H8.7zM8.7 4.6V1.1c.7.6 1.4 1.9 1.7 3.5H8.7z
                                    M11.1 7.3H13c-.1-1.2-.4-2.3-.8-3.2 1.3.7 2.3 1.8 2.8 3.2h-2z
                                    M13 8.7h-1.9c-.1 1.2-.4 2.3-.8 3.2 1.3-.7 2.3-1.8 2.7-3.2z"
                              Stretch="Uniform"/>
                    </Viewbox>
                    <TextBlock Text="SemaBuzz.me" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            </StackPanel>

            <!-- Divider -->
            <Rectangle Height="1" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 0 0 20"/>

            <!-- Copyright section -->
            <TextBlock Text="COPYRIGHT"
                       Foreground="{DynamicResource AmberBrush}"
                       FontWeight="Bold" FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 10"/>

            <TextBlock Text="Copyright &#169; 2026 Skynr Labs. All rights reserved."
                       Foreground="#9E9E9E" FontSize="10"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0 0 0 8"/>

            <TextBlock Text="The SemaBuzz relay server is separately licensed under the GNU Affero General Public License v3.0 (AGPL-3.0). Relay source code is available on GitHub."
                       Foreground="#6E6E6E" FontSize="10"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0 0 0 0"/>

        </StackPanel>

        <!-- Separator -->
        <Rectangle Grid.Row="3" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="20 0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button Style="{StaticResource SemaBuzzButton}"
                        Content="Privacy"
                        VerticalAlignment="Center"
                        Margin="0 0 8 0"
                        Click="Privacy_Click"/>
                <Button Style="{StaticResource SemaBuzzButton}"
                        Content="Terms"
                        VerticalAlignment="Center"
                        Click="Terms_Click"/>
            </StackPanel>
            <Button Style="{StaticResource SemaBuzzButton}" Content="CLOSE"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Click="Close_Click"/>
        </Grid>

    </Grid>
    </Border>
</Window>
