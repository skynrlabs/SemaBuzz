<Window x:Class="SemaBuzz.App.WalkUrlDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz — Walk the Web"
        Height="190" Width="420"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Border BorderBrush="{DynamicResource WindowHeaderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowHeaderBrush}"
              MouseLeftButtonDown="Header_MouseDown">
            <TextBlock Text="WALK THE WEB"
                       VerticalAlignment="Center" Margin="20 0"
                       Foreground="{DynamicResource AmberHeaderBrush}"
                       FontWeight="Bold" FontSize="13"/>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Body -->
        <StackPanel Grid.Row="2" Margin="20 16 20 0" VerticalAlignment="Top">
            <TextBlock Text="URL TO PUSH"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource DimTextBrush}"
                       Margin="0 0 0 6"/>
            <TextBox x:Name="UrlBox"
                     Style="{StaticResource SemaBuzzInput}"
                     KeyDown="UrlBox_KeyDown"/>
        </StackPanel>

        <!-- Separator -->
        <Rectangle Grid.Row="3" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Footer buttons -->
        <Grid Grid.Row="4" Background="{DynamicResource WindowHeaderBrush}" Margin="20 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1"
                    Style="{StaticResource SemaBuzzButton}"
                    Content="CANCEL"
                    Width="90" Height="32" Margin="0 0 8 0"
                    Click="Cancel_Click"/>
            <Button Grid.Column="2"
                    Style="{StaticResource SemaBuzzButton}"
                    Content="PUSH"
                    Width="90" Height="32"
                    IsDefault="True"
                    Click="Push_Click"/>
        </Grid>
    </Grid>
    </Border>
</Window>
