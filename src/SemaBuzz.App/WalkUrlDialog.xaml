<Window x:Class="SemaBuzz.App.WalkUrlDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz — Walk the Web"
        Height="200" Width="420"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource AmberBrush}"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Border x:Name="OuterBorder" BorderBrush="{DynamicResource WindowHeaderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowHeaderBrush}"
              MouseLeftButtonDown="Header_MouseDown">
            <TextBlock Text="WALK THE WEB"
                       VerticalAlignment="Center" Margin="20 0"
                       Foreground="{DynamicResource AmberHeaderBrush}"
                       FontWeight="Bold" FontSize="13"/>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Body -->
        <StackPanel Grid.Row="2" Margin="28 18 28 0" VerticalAlignment="Top">
            <TextBlock Text="URL TO PUSH"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource WireDeadBrush}"
                       Margin="0 0 0 6"/>
            <TextBox x:Name="UrlBox"
                     Style="{StaticResource SemaBuzzInput}"
                     KeyDown="UrlBox_KeyDown"/>
            <TextBlock x:Name="UrlErrorText"
                       Text=""
                       Foreground="#FF5252"
                       FontSize="10"
                       Visibility="Collapsed"
                       Margin="0 6 0 0"/>
        </StackPanel>

        <!-- Separator -->
        <Rectangle Grid.Row="3" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Footer buttons -->
        <Grid Grid.Row="4" Background="{DynamicResource WindowHeaderBrush}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0 0 20 0">
                <Button Style="{StaticResource SemaBuzzButton}"
                        Content="CANCEL"
                        Width="90" Height="32" Margin="0 0 8 0"
                        Click="Cancel_Click"/>
                <Button Style="{StaticResource SemaBuzzButton}"
                        Content="PUSH"
                        Width="90" Height="32"
                        IsDefault="True"
                        Click="Push_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
    </Border>
</Window>
