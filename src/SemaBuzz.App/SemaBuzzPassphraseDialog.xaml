<Window x:Class="SemaBuzz.App.SemaBuzzPassphraseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz — Passphrase Required"
        Height="200" Width="400"
        Background="#121212" Foreground="#FFB300"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <StackPanel Margin="24 20">

        <TextBlock x:Name="HintLabel"
                   Text="» host requires a passphrase"
                   Foreground="#666666" FontSize="11" FontStyle="Italic"
                   Margin="0 0 0 4"/>

        <TextBlock Text="This connection is encrypted. Enter the shared passphrase:"
                   Foreground="#FFB300" Margin="0 0 0 12" TextWrapping="Wrap"/>

        <PasswordBox x:Name="PassphraseBox"
                     Background="#1E1E1E"
                     Foreground="#FFB300"
                     BorderBrush="#444444"
                     BorderThickness="0 0 0 1"
                     Padding="6 6"
                     Margin="0 0 0 20"
                     KeyDown="PassphraseBox_KeyDown"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource SemaBuzzButton}" Content="CANCEL"
                    Margin="0 0 8 0" Click="Cancel_Click"/>
            <Button Style="{StaticResource SemaBuzzButton}" Content="CONNECT"
                    Click="Connect_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
