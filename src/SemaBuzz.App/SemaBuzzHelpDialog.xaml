<Window x:Class="SemaBuzz.App.SemaBuzzHelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz — FAQ"
        Height="680" Width="520"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource AmberBrush}"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowHeaderBrush}"
              MouseLeftButtonDown="Header_MouseDown">
            <TextBlock Text="FAQ"
                       VerticalAlignment="Center" Margin="20 0"
                       FontWeight="Bold" FontSize="13"/>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- FAQ content -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24 18 24 18">
            <StackPanel>

                <!-- Intro banner -->
                <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1"
                        CornerRadius="4" Padding="14 10" Margin="0 0 0 20">
                    <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="12"
                               Text="SemaBuzz is a private, encrypted 1-to-1 communication tool. No accounts. No servers storing your messages. Everything is end-to-end encrypted and lives only on the two devices in the conversation."/>
                </Border>

                <!-- Q1 -->
                <TextBlock Text="How do I start a session as the HOST?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="1.  Click WIRE → Connect in the menu."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="2.  Choose HOST at the top of the dialog."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="3.  You will see a Buzz address — something like buzz://X7K2QP. Click COPY to copy it."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="4.  Send that address to the other person by any means (text message, email, etc.)."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="5.  Click CONNECT and wait. The app will say Warming… until the other person dials in."/>

                <!-- Q2 -->
                <TextBlock Text="How do I dial in and connect to someone?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="1.  Click WIRE → Connect in the menu."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="2.  Choose DIAL at the top of the dialog."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="3.  Paste the Buzz address you received into the Buzz field (e.g. buzz://X7K2QP)."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="4.  Click CONNECT. You will be live as soon as both sides are connected."/>

                <!-- Q3 -->
                <TextBlock Text="What is a Buzz address?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="It looks like buzz://X7K2QP — a short one-time code that tells the relay server which two people belong together. It is only valid for the current session. When you close the connection or click NEW, the old address can never be used again."/>

                <!-- Q4 -->
                <TextBlock Text="Do I need to open any firewall ports or forward my router?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="No. SemaBuzz connects through an encrypted relay over standard HTTPS (port 443). It works on home Wi-Fi, mobile hotspots, office networks, and behind firewalls — no configuration needed."/>

                <!-- Q5 -->
                <TextBlock Text="Is it secure? Can the relay server read my messages?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="No. Every session generates fresh encryption keys on both devices using ECDH (a standard used by Signal and iMessage). The relay only forwards encrypted bytes it cannot read. Even if the relay server were compromised, your messages are unreadable."/>

                <!-- Q6 -->
                <TextBlock Text="Where are my chat logs stored?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="When Permanent Encrypted is enabled in Settings, messages are locked to your Windows account and saved to:"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="{DynamicResource AmberBrush}" FontSize="11"
                           Text="%APPDATA%\SemaBuzz\chatlog.bin"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Use VIEW → Open Log to read your history inside the app. The file is not readable outside of SemaBuzz."/>

                <!-- Q7 -->
                <TextBlock Text="What is Live Preview and should I turn it off?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Live Preview streams every keystroke to the other person as you type — they see each letter appear in real time. If you prefer to compose privately and send all at once, open SETTINGS → Preferences and uncheck 'Stream typing live to peer'. Press Enter to send."/>

                <!-- Q8 -->
                <TextBlock Text="The connection dropped. What do I do?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Click WIRE → Disconnect if it is still shown, then WIRE → Connect again. The host generates a new Buzz address and shares it with the other person. Your on-screen chat history stays visible."/>

                <!-- Q9 — for family/non-technical users -->
                <TextBlock Text="I'm not technical — what do I actually need to know?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <Border Background="#1A1A1A" BorderBrush="#444" BorderThickness="1"
                        CornerRadius="4" Padding="14 10" Margin="0 0 0 20">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="12" Margin="0 0 0 6"
                                   Text="Think of it like a one-time phone call, but for text and images:"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="12" Margin="0 0 0 4"
                                   Text="•  One person hosts (like answering the phone)."/>
                        <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="12" Margin="0 0 0 4"
                                   Text="•  They send you a short code (buzz://XXXXXX) by any means."/>
                        <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="12" Margin="0 0 0 4"
                                   Text="•  You paste that code into the DIAL box and click CONNECT."/>
                        <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="12" Margin="0 0 0 6"
                                   Text="•  You're connected. Type and press Enter to send."/>
                        <TextBlock TextWrapping="Wrap" Foreground="#888" FontSize="11"
                                   Text="Nothing is stored on any server. Close the app when you're done and the session is gone."/>
                    </StackPanel>
                </Border>

                <!-- Q10 -->
                <TextBlock Text="Can I use a custom name / profile?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Yes — enter a handle in the identity section of the connect dialog, or save it as a named profile for quick re-use. Your name is sent to the other person when the session starts so they know who they're talking to."/>

            </StackPanel>
        </ScrollViewer>

        <!-- Separator -->
        <Rectangle Grid.Row="3" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="20 0">
            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                    Style="{StaticResource SemaBuzzButton}"
                    Content="CLOSE"
                    Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
