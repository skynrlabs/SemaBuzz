<Window x:Class="SemaBuzz.App.SemaBuzzHelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz — FAQ"
        Height="560" Width="540"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource AmberBrush}"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Border BorderBrush="{DynamicResource WindowHeaderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowHeaderBrush}"
              MouseLeftButtonDown="Header_MouseDown">
            <TextBlock Text="FAQ"
                       VerticalAlignment="Center" Margin="20 0"
                       Foreground="{DynamicResource AmberHeaderBrush}"
                       FontWeight="Bold" FontSize="13"/>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- FAQ content -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Padding="24 18 24 18">
            <StackPanel>

                <!-- Intro banner -->
                <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1"
                        CornerRadius="4" Padding="14 10" Margin="0 0 0 20">
                    <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="12"
                               Text="SemaBuzz is a private, encrypted 1-to-1 communication tool. No accounts. Messages are encrypted on your device using ECDH P-256 and AES-256-GCM before leaving it. The relay server forwards your packets but holds no keys and can never read them."/>
                </Border>

                <!-- ─── GETTING CONNECTED ─── -->
                <TextBlock Text="GETTING CONNECTED"
                           Foreground="{DynamicResource AmberBrush}" FontSize="10"
                           FontWeight="Bold" Opacity="0.55" Margin="0 0 0 12"/>

                <TextBlock Text="How do I create a buzz and host a session?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="1.  On the main screen click CREATE A BUZZ."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="2.  A 6-character Buzz code appears (e.g. X7K2QP). Click COPY to copy it."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="3.  Send that code to the other person by any means — text, email, etc."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="4.  SemaBuzz waits. As soon as they join you will both be live."/>

                <TextBlock Text="How do I join someone else's session?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="1.  Type or paste the 6-character Buzz code into the 'Join a Buzz' box on the main screen."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="2.  Press Enter or click JOIN. You will be connected once the host approves."/>

                <TextBlock Text="What is a Buzz code?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="A 6-character one-time code (e.g. X7K2QP) that pairs two people on the same relay. It is only valid for the current session — when either side disconnects the code expires and can never be reused."/>

                <TextBlock Text="What happens when someone requests to connect to me?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="An approval prompt appears showing the requester's handle and a countdown timer. Click APPROVE to let them in or DENY to refuse. If the timer expires without a response the request is automatically denied."/>

                <!-- ─── SECURITY &amp; RELAY ─── -->
                <Rectangle Height="1" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 4 0 14"/>
                <TextBlock Text="SECURITY &amp; RELAY"
                           Foreground="{DynamicResource AmberBrush}" FontSize="10"
                           FontWeight="Bold" Opacity="0.55" Margin="0 0 0 12"/>

                <TextBlock Text="Is it secure? Can the relay server read my messages?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="No. Every session generates a fresh key pair on both devices using ECDH P-256 — the same approach used by Signal and iMessage. All data is encrypted with AES-256-GCM on your device before it leaves. The relay only forwards opaque bytes it cannot read; even a compromised relay reveals nothing."/>

                <TextBlock Text="What is a relay server and do I need one?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Yes, a relay is required. It acts as a rendezvous point — no direct connection is made between your computers. You or your peer must run a SemaBuzz Relay server and enter its WebSocket address in SETTINGS → Preferences."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12">
                    <Run Text="The relay is open-source (MIT) and available "/>
                    <Hyperlink NavigateUri="https://github.com/skynrlabs/SemaBuzz-Relay/releases/tag/v1.1.0"
                               Foreground="{DynamicResource AmberBrush}"
                               RequestNavigate="Hyperlink_RequestNavigate">here</Hyperlink>
                    <Run Text=". It uses a standard WebSocket on port 7171 by default — no special firewall rules needed on client machines."/>
                </TextBlock>

                <TextBlock Text="How do I test that my relay is working?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Open a browser and navigate to your relay's HTTP address (e.g. http://localhost:7171). You should see a short health response — this confirms the relay is up and listening."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="If you see 'WebSocket upgrade required' that is also correct — it means the relay is running and waiting for a WebSocket connection from the app. A plain browser request is not a WebSocket, so that message is expected."/>

                <!-- ─── MESSAGING FEATURES ─── -->
                <Rectangle Height="1" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 4 0 14"/>
                <TextBlock Text="MESSAGING FEATURES"
                           Foreground="{DynamicResource AmberBrush}" FontSize="10"
                           FontWeight="Bold" Opacity="0.55" Margin="0 0 0 12"/>

                <TextBlock Text="What is Live Preview?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Live Preview streams every keystroke to the other person as you type — they see each letter appear in real time. To compose privately instead, open SETTINGS → Preferences and uncheck 'Stream typing live to peer'. Either way, press Enter to send the finished message."/>

                <TextBlock Text="What is the BuzzIndicator (the bar at the bottom)?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="The BuzzIndicator is a visual typing meter. Its filament glows and pulses as the other person types, so you know they are actively composing even if Live Preview is off. Adjust its sensitivity and visual style in SETTINGS → Preferences."/>

                <TextBlock Text="What does the ⚡ Buzz button do?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Sends a 'buzz' — a short electrical pulse animation that fires on the other person's BuzzIndicator. Use it to get their attention without typing anything."/>

                <TextBlock Text="How do I send an emoji?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Click the 😊 button in the input area to open the emoji picker. Categories include faces, gestures, symbols, animals, food, travel, activities, and objects. Click any emoji to insert it into your message."/>

                <!-- ─── FILES &amp; SHARING ─── -->
                <Rectangle Height="1" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 4 0 14"/>
                <TextBlock Text="FILES &amp; SHARING"
                           Foreground="{DynamicResource AmberBrush}" FontSize="10"
                           FontWeight="Bold" Opacity="0.55" Margin="0 0 0 12"/>

                <TextBlock Text="How do I send a file?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Click the 📎 button, choose a file, and confirm. The other person sees a file transfer card with ACCEPT and DECLINE buttons."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Once they accept, the file transfers via the relay. A SHA-256 checksum is verified on receipt to confirm the file arrived intact."/>

                <TextBlock Text="What is Walk Web (the 🌐 button)?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Walk Web pushes a URL directly to the other person — a clickable link appears instantly in their chat pane. Useful for sharing a webpage without sending it as plain text in a message."/>

                <TextBlock Text="How do I use the Whiteboard (✏)?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Click the ✏ button to open the shared drawing board. Both sides can draw simultaneously and see each other's strokes in real time. The whiteboard stays open while you continue chatting."/>

                <!-- ─── IDENTITY &amp; STATUS ─── -->
                <Rectangle Height="1" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 4 0 14"/>
                <TextBlock Text="IDENTITY &amp; STATUS"
                           Foreground="{DynamicResource AmberBrush}" FontSize="10"
                           FontWeight="Bold" Opacity="0.55" Margin="0 0 0 12"/>

                <TextBlock Text="Can I use a custom name / profile?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Yes. Go to SETTINGS → Profiles to create or edit named profiles with a handle and avatar. Your active profile name is sent to the other person when a session starts so they know who they're talking to. Switch profiles at any time from the profile badge in the top-right corner."/>

                <TextBlock Text="How do I set my status (Available / Away / Busy)?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Click the profile badge in the top-right corner. A menu lets you choose Available, Away, or Busy and optionally type a custom status message. Your status is shown to peers when you connect."/>

                <!-- ─── SETTINGS &amp; LOOK ─── -->
                <Rectangle Height="1" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 4 0 14"/>
                <TextBlock Text="SETTINGS &amp; LOOK"
                           Foreground="{DynamicResource AmberBrush}" FontSize="10"
                           FontWeight="Bold" Opacity="0.55" Margin="0 0 0 12"/>

                <TextBlock Text="How do I change the theme?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Open SETTINGS → Themes. A grid of all available themes is shown with a live preview — click one to preview, then OK to save or Cancel to revert to your previous theme."/>

                <TextBlock Text="What can I configure in Preferences?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="SETTINGS → Preferences lets you set the relay server address, toggle Live Preview, adjust BuzzIndicator sensitivity, and choose the indicator visual style."/>

                <!-- ─── WINDOW &amp; SYSTEM ─── -->
                <Rectangle Height="1" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 4 0 14"/>
                <TextBlock Text="WINDOW &amp; SYSTEM"
                           Foreground="{DynamicResource AmberBrush}" FontSize="10"
                           FontWeight="Bold" Opacity="0.55" Margin="0 0 0 12"/>

                <TextBlock Text="Can I minimize SemaBuzz to the system tray?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="Yes. Minimizing the window hides it to the system tray. Double-click the tray icon to restore it. A live session continues running while minimized."/>

                <TextBlock Text="What is Always on Top?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="WIRE → Always on Top keeps the SemaBuzz window floating above all other windows, even when you focus on another application. Useful when monitoring an active session while working in another program."/>

                <!-- ─── TROUBLESHOOTING ─── -->
                <Rectangle Height="1" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 4 0 14"/>
                <TextBlock Text="TROUBLESHOOTING"
                           Foreground="{DynamicResource AmberBrush}" FontSize="10"
                           FontWeight="Bold" Opacity="0.55" Margin="0 0 0 12"/>

                <TextBlock Text="The connection dropped. What do I do?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="When a connection drops, SemaBuzz automatically returns to the main screen — no manual disconnect is needed."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="The host clicks CREATE A BUZZ to generate a new code and shares it with the other person."/>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 20"
                           Foreground="#AAAAAA" FontSize="12"
                           Text="The other person enters the new code and clicks JOIN. Your on-screen chat history stays visible."/>

                <TextBlock Text="I'm not technical — what do I actually need to know?"
                           Foreground="{DynamicResource AmberBrush}"
                           FontWeight="Bold" Margin="0 0 0 4"/>
                <Border Background="#1A1A1A" BorderBrush="#444" BorderThickness="1"
                        CornerRadius="4" Padding="14 10" Margin="0 0 0 20">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="12" Margin="0 0 0 6"
                                   Text="Think of it like a one-time phone call, but for text and files:"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="12" Margin="0 0 0 4"
                                   Text="•  One person clicks CREATE A BUZZ and sends the code to the other."/>
                        <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="12" Margin="0 0 0 4"
                                   Text="•  The other types that code in the box and clicks JOIN."/>
                        <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="12" Margin="0 0 0 6"
                                   Text="•  You're connected. Type and press Enter to send."/>
                        <TextBlock TextWrapping="Wrap" Foreground="#888" FontSize="11"
                                   Text="Nothing is stored on any server. Close the app when you're done and the session is gone."/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Separator -->
        <Rectangle Grid.Row="3" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="20 0">
            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                    Style="{StaticResource SemaBuzzButton}"
                    Content="CLOSE"
                    Click="Close_Click"/>
        </Grid>
    </Grid>
    </Border>
</Window>
