<Window x:Class="SemaBuzz.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SemaBuzz.App.Controls"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="SemaBuzz" Height="560" Width="820"
        MinHeight="560" MinWidth="820"
        Icon="Assets/icon.ico"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource AmberBrush}"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <!-- Extend client area into the title bar so DWM stops drawing its own
         title text and icon. CaptionHeight=52 matches the unified header row.
         DWM still renders the min/max/close buttons in the top-right corner;
         DWMWA_CAPTION_COLOR (#121212) colours the area behind them. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="52"
                      ResizeBorderThickness="4"
                      UseAeroCaptionButtons="False"
                      GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="SemaBuzzInputRTB" TargetType="emoji:RichTextBox">
            <Setter Property="Background"         Value="{DynamicResource ObsidianSurfaceBrush}"/>
            <Setter Property="Foreground"         Value="{DynamicResource AmberBrush}"/>
            <Setter Property="CaretBrush"         Value="{DynamicResource AmberBrush}"/>
            <Setter Property="BorderBrush"        Value="{DynamicResource AmberDimBrush}"/>
            <Setter Property="BorderThickness"    Value="0 0 0 1"/>
            <Setter Property="FontFamily"         Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize"           Value="14"/>
            <Setter Property="Padding"            Value="6 4"/>
            <Setter Property="SelectionBrush"     Value="{DynamicResource AmberDimBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RichTextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AmberBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dim disabled menu items to grey -->
        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>   <!-- Unified header -->
            <RowDefinition Height="1"/>    <!-- Separator -->
            <RowDefinition Height="Auto"/> <!-- Trial / license banner -->
            <RowDefinition Height="*"/>    <!-- Chat -->
            <RowDefinition Height="56"/>   <!-- BuzzIndicator -->
            <RowDefinition Height="1"/>    <!-- Separator -->
            <RowDefinition Height="Auto"/> <!-- Input -->
            <RowDefinition Height="1"/>    <!-- Separator -->
            <RowDefinition Height="44"/>   <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Unified Header: brand · menu · wire status · window controls -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowHeaderBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- Brand -->
                <ColumnDefinition Width="1"/>     <!-- Divider -->
                <ColumnDefinition Width="*"/>     <!-- Menu -->
                <ColumnDefinition Width="1"/>     <!-- Divider -->
                <ColumnDefinition Width="Auto"/>  <!-- Profile badge -->
                <ColumnDefinition Width="1"/>     <!-- Divider -->
                <ColumnDefinition Width="Auto"/>  <!-- Window controls -->
            </Grid.ColumnDefinitions>

            <!-- Brand -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20 0 18 0">
                <TextBlock Text="SEMA" Foreground="{DynamicResource AmberHeaderBrush}" FontWeight="Bold"   FontSize="17"/>
                <TextBlock Text="BUZZ" Foreground="{DynamicResource AmberHeaderBrush}" FontWeight="Light"  FontSize="17"/>
            </StackPanel>

            <!-- Vertical divider -->
            <Rectangle Grid.Column="1" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 12"/>

            <!-- Inline menu -->
            <Menu Grid.Column="2" VerticalAlignment="Center" Margin="4 0"
                  WindowChrome.IsHitTestVisibleInChrome="True">
                <MenuItem Header="WIRE">
                    <MenuItem Header="Disconnect" x:Name="DisconnectMenuItem" IsEnabled="False" Click="Wire_Disconnect_Click"/>
                    <Separator/>
                    <MenuItem Header="Always on Top" x:Name="AlwaysOnTopMenuItem" IsCheckable="True" Click="Wire_AlwaysOnTop_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="Wire_Exit_Click"/>
                </MenuItem>
                <MenuItem Header="VIEW">
                    <MenuItem Header="Clear Chat" x:Name="ClearChatMenuItem" IsEnabled="False" Click="View_ClearChat_Click"/>
                </MenuItem>
                <MenuItem Header="SETTINGS">
                    <MenuItem Header="Themes" Click="Settings_Themes_Click"/>
                    <Separator/>
                    <MenuItem Header="Profiles" x:Name="ProfilesMenuItem" Click="Settings_Profiles_Click"/>
                    <Separator/>
                    <MenuItem Header="Preferences" Click="Settings_Preferences_Click"/>
                </MenuItem>
                <MenuItem Header="HELP">
                    <MenuItem Header="About" Click="Help_About_Click"/>
                    <Separator/>
                    <MenuItem Header="Help / FAQ" Click="Help_FAQ_Click"/>
                    <Separator/>
                    <MenuItem Header="News &amp; Updates" Click="Help_NewsUpdates_Click"/>
                </MenuItem>
            </Menu>

            <!-- Vertical divider -->
            <Rectangle Grid.Column="3" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 12"/>

            <!-- Profile badge -->
            <Button Grid.Column="4"
                    x:Name="ProfileBadgeBtn"
                    Style="{StaticResource SemaBuzzWinButton}"
                    Width="Auto"
                    VerticalAlignment="Stretch"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="ProfileBadge_Click"
                    ToolTip="{Binding Text, ElementName=ProfileBadgeLabel}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14 0">
                    <Ellipse x:Name="ProfileBadgeAvatar"
                             Width="22" Height="22"
                             Fill="{DynamicResource ObsidianBrush}"
                             Stroke="{DynamicResource ObsidianBorderBrush}"
                             StrokeThickness="1"
                             Margin="0 0 8 0"/>
                    <TextBlock x:Name="ProfileBadgeLabel"
                               Text="ANONYMOUS"
                               VerticalAlignment="Center"
                               FontSize="11"
                               MaxWidth="200"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource AmberHeaderBrush}"/>
                    <Ellipse x:Name="ProfileStatusDot"
                             Width="10" Height="10"
                             Margin="6 0 0 0"
                             VerticalAlignment="Center"
                             Fill="#4CAF50"/>
                </StackPanel>
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="● Available" Tag="Available" Click="StatusMenu_Click"/>
                        <MenuItem Header="◑ Away"      Tag="Away"      Click="StatusMenu_Click"/>
                        <MenuItem Header="● Busy"      Tag="Busy"      Click="StatusMenu_Click"/>
                        <Separator/>
                        <MenuItem Header="Set status message..." Click="StatusMessage_Click"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

            <!-- Vertical divider -->
            <Rectangle Grid.Column="5" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 12"/>

            <!-- Window controls: minimize · maximize/restore · close -->
            <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Stretch"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinimizeButton"
                        Style="{StaticResource SemaBuzzWinButton}"
                        ToolTip="Minimize"
                        Click="WinBtn_Minimize_Click">
                    <TextBlock Text="&#x2013;" FontSize="14" Foreground="{DynamicResource AmberHeaderBrush}"/>
                </Button>
                <Button x:Name="MaximizeButton"
                        Style="{StaticResource SemaBuzzWinButton}"
                        ToolTip="Maximize"
                        Click="WinBtn_Maximize_Click">
                    <TextBlock x:Name="MaximizeGlyph" Text="&#x25A1;" FontSize="12" Foreground="{DynamicResource AmberHeaderBrush}"/>
                </Button>
                <Button x:Name="CloseButton"
                        Style="{StaticResource SemaBuzzWinButtonClose}"
                        ToolTip="Close"
                        Click="WinBtn_Close_Click">
                    <TextBlock Text="&#x2715;" FontSize="12" Foreground="{DynamicResource AmberHeaderBrush}"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Trial / license banner (hidden when fully purchased) -->
        <Border x:Name="TrialBanner"
                Grid.Row="2"
                Padding="20 7"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TrialBannerLabel"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           FontStyle="Italic"/>
                <Button x:Name="BuyNowButton"
                        Grid.Column="1"
                        Style="{StaticResource SemaBuzzButton}"
                        Content="BUY NOW"
                        FontSize="11"
                        Padding="10 3"
                        Click="BuyNowButton_Click"/>
            </Grid>
        </Border>

        <!-- Two-pane chat area: local (left) | peer (right) -->
        <Grid x:Name="ChatPanesGrid" Grid.Row="3" Background="{DynamicResource WindowBackgroundBrush}" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Local pane -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="{DynamicResource WindowHeaderBrush}"
                        Height="52"
                        Padding="14 0">
                    <Grid VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="LocalStatusDot"
                                     Width="10" Height="10"
                                     Margin="0 0 6 0"
                                     VerticalAlignment="Center"
                                     Fill="#4CAF50"/>
                            <TextBlock x:Name="LocalPaneLabel"
                                       Text="YOU"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AmberBrush}"
                                       Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal"
                                    x:Name="LocalStatusMsgRow"
                                    Margin="0 6 0 0"
                                    Visibility="Collapsed">
                            <TextBlock Text="›"
                                       FontSize="10"
                                       Foreground="{DynamicResource AmberBrush}"
                                       Opacity="0.55"
                                       Margin="0 0 4 0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="LocalStatusMsg"
                                       Text=""
                                       FontSize="10"
                                       Foreground="{DynamicResource AmberBrush}"
                                       Opacity="0.55"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1"
                              x:Name="LocalScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14 10">
                    <StackPanel x:Name="LocalPanel" Orientation="Vertical"/>
                </ScrollViewer>
            </Grid>

            <!-- Divider -->
            <Rectangle Grid.Column="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

            <!-- Peer pane -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="{DynamicResource WindowHeaderBrush}"
                        Height="52"
                        Padding="14 0">
                    <Grid VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="PeerStatusDot"
                                     Width="10" Height="10"
                                     Margin="0 0 6 0"
                                     VerticalAlignment="Center"
                                     Fill="#616161"/>
                            <TextBlock x:Name="PeerPaneLabel"
                                       Text="PEER"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#9E9E9E"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal"
                                    x:Name="PeerStatusMsgRow"
                                    Margin="0 6 0 0"
                                    Visibility="Collapsed">
                            <TextBlock Text="›"
                                       FontSize="10"
                                       Foreground="{DynamicResource AmberBrush}"
                                       Opacity="0.55"
                                       Margin="0 0 4 0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="PeerStatusMsg"
                                       Text=""
                                       FontSize="10"
                                       Foreground="{DynamicResource AmberBrush}"
                                       Opacity="0.55"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1"
                              x:Name="PeerScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14 10">
                    <StackPanel x:Name="PeerPanel" Orientation="Vertical"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Buzz Code Banner — shown on startup, while hosting, and on incoming request -->
        <Grid x:Name="BuzzCodeBanner"
              Grid.Row="3"
              Background="{DynamicResource WindowBackgroundBrush}"
              Visibility="Visible">
            <Border Margin="40 16"
                    Background="{DynamicResource ObsidianSurfaceBrush}"
                    BorderBrush="{DynamicResource ObsidianBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="40 28">
                <Grid VerticalAlignment="Center">

                    <!-- Idle state: join a buzz or start a new one -->
                    <StackPanel x:Name="BuzzIdleState"
                                Width="320"
                                HorizontalAlignment="Center">

                        <TextBlock Text="Join a Buzz"
                                   FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource AmberBrush}"
                                   Margin="0 0 0 14"/>

                        <!-- Single rounded token input with spaced letters -->
                        <TextBox x:Name="InlineTokenInput"
                                 MaxLength="6"
                                 FontSize="20"
                                 FontWeight="Bold"
                                 CharacterCasing="Upper"
                                 FontFamily="Cascadia Code, Consolas"
                                 Foreground="Transparent"
                                 CaretBrush="{DynamicResource AmberBrush}"
                                 SelectionBrush="{DynamicResource AmberDimBrush}"
                                 FocusVisualStyle="{x:Null}"
                                 PreviewTextInput="InlineTokenInput_PreviewTextInput"
                                 PreviewKeyDown="InlineTokenInput_PreviewKeyDown"
                                 TextChanged="InlineTokenInput_TextChanged">
                            <TextBox.Template>
                                <ControlTemplate TargetType="TextBox">
                                    <Border x:Name="InputBorder"
                                            CornerRadius="8"
                                            BorderBrush="{DynamicResource AmberDimBrush}"
                                            BorderThickness="1"
                                            Background="{DynamicResource WindowHeaderDimBrush}"
                                            Width="320"
                                            Height="44">
                                        <Grid Background="Transparent">
                                            <!-- Centered row: spaced text + blinking caret -->
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock x:Name="SpacedDisplay"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Cascadia Code, Consolas"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource AmberBrush}"/>
                                                <!-- Fake blinking caret -->
                                                <Rectangle x:Name="FakeCaret"
                                                           Width="2" Height="22"
                                                           Margin="3 0 0 0"
                                                           VerticalAlignment="Center"
                                                           Fill="{DynamicResource AmberBrush}"
                                                           Visibility="Collapsed">
                                                    <Rectangle.Effect>
                                                        <DropShadowEffect x:Name="CaretGlow"
                                                                          BlurRadius="8"
                                                                          ShadowDepth="0"
                                                                          Opacity="0.95"
                                                                          Color="#FFB300"/>
                                                    </Rectangle.Effect>
                                                </Rectangle>
                                            </StackPanel>
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          HorizontalAlignment="Stretch"
                                                          VerticalAlignment="Stretch"
                                                          HorizontalScrollBarVisibility="Hidden"
                                                          VerticalScrollBarVisibility="Hidden"
                                                          Opacity="0"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard x:Name="CaretBlink">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation
                                                            Storyboard.TargetName="FakeCaret"
                                                            Storyboard.TargetProperty="Opacity"
                                                            From="1" To="0"
                                                            Duration="0:0:0.55"
                                                            AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="CaretBlink"/>
                                            </Trigger.ExitActions>
                                            <Setter TargetName="InputBorder" Property="BorderBrush"
                                                    Value="{DynamicResource AmberBrush}"/>
                                            <Setter TargetName="FakeCaret" Property="Visibility"
                                                    Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>

                        <TextBlock Text="Enter the buzz code, then press Enter"
                                   Foreground="#9E9E9E" FontSize="10"
                                   HorizontalAlignment="Center"
                                   Margin="0 7 0 0"/>

                        <Button x:Name="InlineConnectBtn"
                                Style="{StaticResource SemaBuzzButton}"
                                Content="JOIN"
                                IsEnabled="False"
                                HorizontalAlignment="Center"
                                Width="320"
                                Padding="0 10"
                                Margin="0 14 0 0"
                                Click="InlineConnect_Click"/>

                        <Grid Width="320" Margin="0 20 0 20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Height="1"
                                       Fill="{DynamicResource ObsidianBorderBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="or"
                                       Foreground="{DynamicResource ObsidianBorderBrush}" FontSize="10"
                                       Margin="12 0"/>
                            <Rectangle Grid.Column="2" Height="1"
                                       Fill="{DynamicResource ObsidianBorderBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Button Style="{StaticResource SemaBuzzButton}"
                                Content="CREATE A BUZZ"
                                HorizontalAlignment="Center"
                                Width="320"
                                Padding="0 10"
                                Click="InlineStartBuzz_Click"/>

                    </StackPanel>

                    <!-- Waiting state -->
                    <StackPanel x:Name="BuzzWaitingState" Visibility="Collapsed"
                               HorizontalAlignment="Center">
                        <TextBlock Text="Your buzz is live"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#9E9E9E"
                                   Margin="0 0 0 20"/>
                        <TextBlock x:Name="BuzzCodeBannerLabel"
                                   HorizontalAlignment="Center"
                                   FontFamily="Cascadia Code, Consolas"
                                   FontSize="52"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AmberBrush}"
                                   Margin="0 0 0 20">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FFB300" BlurRadius="22" ShadowDepth="0" Opacity="0.6"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Waiting for someone to join..."
                                   HorizontalAlignment="Center"
                                   FontSize="11"
                                   FontStyle="Italic"
                                   Foreground="#9E9E9E"
                                   Margin="0 0 0 28"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="BuzzCodeCopyBtn"
                                    Style="{StaticResource SemaBuzzButton}"
                                    Content="COPY"
                                    Padding="18 5"
                                    Margin="0 0 8 0"
                                    Click="CopyBuzzCode_Click"/>
                            <Button Style="{StaticResource SemaBuzzButton}"
                                    Content="CANCEL"
                                    Padding="18 5"
                                    Click="CancelWait_Click"/>
                        </StackPanel>
                        <StackPanel x:Name="CustomRelayWarning"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Center"
                                    Margin="0 16 0 0">
                            <TextBlock x:Name="CustomRelayWarningMsg"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="480"
                                       FontSize="10"
                                       Foreground="#FF9800"/>
                            <TextBlock x:Name="CustomRelayWarningUri"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontFamily="Cascadia Code, Consolas"
                                       FontSize="10"
                                       Foreground="#FF9800"
                                       Margin="0 4 0 0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Incoming request state -->
                    <StackPanel x:Name="BuzzRequestState" Visibility="Collapsed" HorizontalAlignment="Center">
                        <TextBlock Text="Incoming wire request"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#9E9E9E"
                                   Margin="0 0 0 16"/>
                        <TextBlock x:Name="BuzzRequestFromLabel"
                                   HorizontalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{DynamicResource AmberBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0 0 0 28"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 16">
                            <Button x:Name="ApproveBtn"
                                    Style="{StaticResource SemaBuzzButton}"
                                    Content="APPROVE"
                                    Padding="18 5"
                                    Margin="0 0 10 0"
                                    Click="Approve_Click"/>
                            <Button x:Name="DenyBtn"
                                    Style="{StaticResource SemaBuzzButton}"
                                    Content="DENY"
                                    Padding="18 5"
                                    Click="Deny_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="BuzzRequestCountdown"
                                   HorizontalAlignment="Center"
                                   FontSize="11"
                                   Foreground="#9E9E9E"/>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>

        <!-- BuzzIndicator -->
        <Border Grid.Row="4" Background="{DynamicResource WindowHeaderBrush}" Padding="20 0">
            <controls:SemaBuzzIndicator x:Name="BuzzIndicator"
                                        FilamentBrush="{DynamicResource AmberHeaderBrush}"
                                        Height="40"
                                        VerticalAlignment="Center"/>
        </Border>

        <!-- Separator -->
        <Rectangle Grid.Row="5" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Input Row -->
        <Grid Grid.Row="6" Background="{DynamicResource ObsidianSurfaceBrush}">
            <emoji:RichTextBox x:Name="InputBox"
                     Style="{StaticResource SemaBuzzInputRTB}"
                     AcceptsReturn="False"
                     Padding="16 12 216 12"
                     VerticalAlignment="Center"
                     Background="{DynamicResource ObsidianSurfaceBrush}"
                     BorderThickness="0"
                     IsEnabled="False"
                     PreviewTextInput="InputBox_PreviewTextInput"
                     PreviewKeyDown="InputBox_PreviewKeyDown"
                     TextChanged="InputBox_TextChanged"
                     DataObject.Pasting="InputBox_Pasting"/>
            <TextBlock x:Name="InputPlaceholder"
                       Text="Say something…"
                       IsHitTestVisible="False"
                       Focusable="False"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Margin="16 0 0 0"
                       FontSize="13"
                       Foreground="{DynamicResource WireDeadBrush}"
                       Opacity="0.45"
                       Visibility="Collapsed"/>
            <Button x:Name="EmoticonPickerButton"
                    Style="{StaticResource SemaBuzzSendButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="36" Height="36"
                    Margin="0 0 90 0"
                    IsEnabled="{Binding IsEnabled, ElementName=InputBox}"
                    ToolTip="Emoticons"
                    Click="EmoticonPickerButton_Click">
                <Button.ContextMenu>
                    <ContextMenu x:Name="EmoticonMenu"
                                 Placement="Top">

                        <!-- ── Faces ── -->
                        <MenuItem>
                            <MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😀" FontSize="16" Margin="0 0 6 0" VerticalAlignment="Center"/><TextBlock Text="Faces ▶" VerticalAlignment="Center"/></StackPanel></MenuItem.Header>
                            <MenuItem Tag="🙂" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🙂" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Smile" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😊" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😊" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Blush" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😉" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😉" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Wink" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😂" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😂" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Laugh" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🤣" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🤣" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="ROFL" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😎" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😎" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Cool" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🤔" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🤔" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Thinking" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
