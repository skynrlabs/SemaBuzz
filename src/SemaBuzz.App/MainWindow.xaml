                            <MenuItem Tag="🧩" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🧩" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Puzzle" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                        </MenuItem>

                        <!-- ── Objects ── -->
                        <MenuItem>
                            <MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="💻" FontSize="16" Margin="0 0 6 0" VerticalAlignment="Center"/><TextBlock Text="Objects ▶" VerticalAlignment="Center"/></StackPanel></MenuItem.Header>
                            <MenuItem Tag="💻" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="💻" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Laptop" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="📱" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="📱" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Phone" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="⌨️" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="⌨️" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Keyboard" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🖥️" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🖥️" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Desktop" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🖨️" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🖨️" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Printer" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="📷" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="📷" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Camera" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="💡" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="💡" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Idea" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🔑" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🔑" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Key" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🔒" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🔒" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Lock" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🔓" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🔓" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Unlock" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="📦" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="📦" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Package" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🗑️" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🗑️" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Trash" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="⚙️" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="⚙️" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Settings" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🧲" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🧲" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Magnet" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                        </MenuItem>

                    </ContextMenu>
                </Button.ContextMenu>
                <emoji:TextBlock Text="😊"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
            <!-- Divider between action buttons and send -->
            <Rectangle HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Width="1" Height="20"
                       Margin="0 0 44 0"
                       Fill="{DynamicResource ObsidianBorderBrush}"/>
            <!-- Buzz button — slam the remote's filament -->
            <Button x:Name="BuzzButton"
                    Style="{StaticResource SemaBuzzSendButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="36" Height="36"
                    Margin="0 0 48 0"
                    IsEnabled="False"
                    ToolTip="Buzz (shock the wire)"
                    Click="BuzzButton_Click">
                <TextBlock Text="⚡"
                           FontSize="16"
                           Foreground="{DynamicResource AmberBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
            <!-- Whiteboard button — open the shared drawing board -->
            <Button x:Name="BoardButton"
                    Style="{StaticResource SemaBuzzSendButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="36" Height="36"
                    Margin="0 0 174 0"
                    IsEnabled="False"
                    ToolTip="Whiteboard — shared drawing board"
                    Click="BoardButton_Click">
                <TextBlock Text="✏"
                           FontSize="16"
                           Foreground="{DynamicResource AmberBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
            <!-- Walk button — push a URL to the peer -->
            <Button x:Name="WalkButton"
                    Style="{StaticResource SemaBuzzSendButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="36" Height="36"
                    Margin="0 0 132 0"
                    IsEnabled="False"
                    ToolTip="Walk the Web — push a URL to your peer"
                    Click="WalkButton_Click">
                <TextBlock Text="🌐"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
            <!-- Send button — overlaid on the right edge of the input -->
            <Button x:Name="SendButton"
                    Style="{StaticResource SemaBuzzSendButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="36" Height="36"
                    Margin="0 0 6 0"
                    IsEnabled="False"
                    ToolTip="Send (Enter)"
                    Click="SendButton_Click">
                <!-- Arrow-right glyph using Segoe UI Symbol / Marlett fallback -->
                <TextBlock Text="⏎"
                           FontSize="16"
                           Foreground="{DynamicResource AmberBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="7" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Status Bar -->
        <Grid Grid.Row="8" Margin="20 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- Wire state indicator -->
                <ColumnDefinition Width="Auto"/>  <!-- Divider -->
                <ColumnDefinition Width="*"/>     <!-- Status messages -->
                <ColumnDefinition Width="Auto"/>  <!-- Peer label -->
            </Grid.ColumnDefinitions>
            <!-- Wire state indicator -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 0 0">
                <Ellipse x:Name="WireStateDot"
                         Width="10" Height="10" Fill="#9E9E9E"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <!-- Divider -->
            <Rectangle Grid.Column="1" Fill="{DynamicResource ObsidianBorderBrush}" Width="1" Margin="14 8"/>
            <!-- Status messages -->
            <TextBlock x:Name="StatusLabel"
                       Grid.Column="2"
                       Style="{StaticResource SemaBuzzStatusLabel}"
                       Text="› wire is cold"
                       VerticalAlignment="Center"/>
            <!-- Peer handle — visible when connected as dialer -->
            <TextBlock x:Name="PeerLabel"
                       Grid.Column="3"
                       Style="{StaticResource SemaBuzzStatusLabel}"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Amber border overlay — follows Win11 rounded corners natively -->
        <Border Grid.Row="0" Grid.RowSpan="9"
                BorderBrush="{DynamicResource WindowHeaderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                IsHitTestVisible="False"/>

    </Grid>
</Window>
