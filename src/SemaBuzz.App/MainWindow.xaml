            <Button x:Name="SendButton"
                    Style="{StaticResource SemaBuzzSendButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="36" Height="36"
                    Margin="0 0 6 0"
                    IsEnabled="False"
                    ToolTip="Send (Enter)"
                    Click="SendButton_Click">
                <!-- Arrow-right glyph using Segoe UI Symbol / Marlett fallback -->
                <TextBlock Text="⏎"
                           FontSize="16"
                           Foreground="{DynamicResource AmberBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
