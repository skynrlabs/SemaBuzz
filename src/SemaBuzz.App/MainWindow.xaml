        <Rectangle Grid.Row="7" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Status Bar -->
        <Grid Grid.Row="8" Background="{DynamicResource WindowHeaderBrush}" Margin="20 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusLabel"
                       Grid.Column="0"
                       Style="{StaticResource SemaBuzzStatusLabel}"
                       Text="› wire is cold"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="PeerLabel"
                       Grid.Column="1"
                       Style="{StaticResource SemaBuzzStatusLabel}"
                       VerticalAlignment="Center"/>
        </Grid>
    </Grid>
