            <Button x:Name="BuzzButton"
                    Style="{StaticResource SemaBuzzSendButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="36" Height="36"
                    Margin="0 0 48 0"
                    IsEnabled="False"
                    ToolTip="Buzz (shock the wire)"
                    Click="BuzzButton_Click">
                <TextBlock Text="⚡"
                           FontSize="16"
                           Foreground="{DynamicResource AmberBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>
