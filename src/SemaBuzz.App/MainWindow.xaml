<Window x:Class="SemaBuzz.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SemaBuzz.App.Controls"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="SemaBuzz" Height="560" Width="820"
        MinHeight="480" MinWidth="640"
        Icon="Assets/icon.ico"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource AmberBrush}"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <!-- Extend client area into the title bar so DWM stops drawing its own
         title text and icon. CaptionHeight=52 matches the unified header row.
         DWM still renders the min/max/close buttons in the top-right corner;
         DWMWA_CAPTION_COLOR (#121212) colours the area behind them. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="52"
                      ResizeBorderThickness="4"
                      UseAeroCaptionButtons="False"
                      GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="SemaBuzzInputRTB" TargetType="emoji:RichTextBox">
            <Setter Property="Background"         Value="{StaticResource ObsidianSurfaceBrush}"/>
            <Setter Property="Foreground"         Value="{StaticResource AmberBrush}"/>
            <Setter Property="CaretBrush"         Value="{StaticResource AmberBrush}"/>
            <Setter Property="BorderBrush"        Value="{StaticResource AmberDimBrush}"/>
            <Setter Property="BorderThickness"    Value="0 0 0 1"/>
            <Setter Property="FontFamily"         Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize"           Value="14"/>
            <Setter Property="Padding"            Value="6 4"/>
            <Setter Property="SelectionBrush"     Value="{StaticResource AmberDimBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RichTextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AmberBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dim disabled menu items to grey -->
        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>   <!-- Unified header -->
            <RowDefinition Height="1"/>    <!-- Separator -->
            <RowDefinition Height="Auto"/> <!-- Trial / license banner -->
            <RowDefinition Height="*"/>    <!-- Chat -->
            <RowDefinition Height="56"/>   <!-- BuzzIndicator -->
            <RowDefinition Height="1"/>    <!-- Separator -->
            <RowDefinition Height="Auto"/> <!-- Input -->
            <RowDefinition Height="1"/>    <!-- Separator -->
            <RowDefinition Height="44"/>   <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Unified Header: brand · menu · wire status · window controls -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowHeaderBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- Brand -->
                <ColumnDefinition Width="1"/>     <!-- Divider -->
                <ColumnDefinition Width="*"/>     <!-- Menu -->
                <ColumnDefinition Width="1"/>     <!-- Divider -->
                <ColumnDefinition Width="Auto"/>  <!-- Wire status -->
                <ColumnDefinition Width="1"/>     <!-- Divider -->
                <ColumnDefinition Width="Auto"/>  <!-- Window controls -->
            </Grid.ColumnDefinitions>

            <!-- Brand -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20 0 18 0">
                <TextBlock Text="SEMA" Foreground="{DynamicResource AmberBrush}" FontWeight="Bold"   FontSize="17"/>
                <TextBlock Text="BUZZ" Foreground="{DynamicResource AmberBrush}" FontWeight="Light"  FontSize="17"/>
            </StackPanel>

            <!-- Vertical divider -->
            <Rectangle Grid.Column="1" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 12"/>

            <!-- Inline menu -->
            <Menu Grid.Column="2" VerticalAlignment="Center" Margin="4 0"
                  WindowChrome.IsHitTestVisibleInChrome="True">
                <MenuItem Header="WIRE">
                    <MenuItem Header="Connect" x:Name="ConnectMenuItem" Click="ConnectButton_Click"/>
                    <MenuItem Header="Disconnect" x:Name="DisconnectMenuItem" IsEnabled="False" Click="Wire_Disconnect_Click"/>
                    <Separator/>
                    <MenuItem Header="Always on Top" x:Name="AlwaysOnTopMenuItem" IsCheckable="True" Click="Wire_AlwaysOnTop_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="Wire_Exit_Click"/>
                </MenuItem>
                <MenuItem Header="VIEW">
                    <MenuItem Header="Clear Chat" Click="View_ClearChat_Click"/>
                </MenuItem>
                <MenuItem Header="SETTINGS">
                    <MenuItem Header="Themes" Click="Settings_Themes_Click"/>
                    <Separator/>
                    <MenuItem Header="Preferences" Click="Settings_Preferences_Click"/>
                </MenuItem>
                <MenuItem Header="HELP">
                    <MenuItem Header="About" Click="Help_About_Click"/>
                    <MenuItem Header="FAQ" Click="Help_FAQ_Click"/>
                    <Separator/>
                    <MenuItem Header="News &amp; Updates" Click="Help_NewsUpdates_Click"/>
                </MenuItem>
            </Menu>

            <!-- Vertical divider -->
            <Rectangle Grid.Column="3" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 12"/>

            <!-- Wire status -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="18 0 18 0">
                <TextBlock x:Name="TitleSessionLabel" Text="NO WIRE"
                           Foreground="#9E9E9E" FontSize="12" VerticalAlignment="Center"/>
                <Ellipse x:Name="WireStateDot"
                         Width="10" Height="10" Fill="#9E9E9E"
                         VerticalAlignment="Center" Margin="12 0 0 0"/>
            </StackPanel>

            <!-- Vertical divider -->
            <Rectangle Grid.Column="5" Fill="{DynamicResource ObsidianBorderBrush}" Margin="0 12"/>

            <!-- Window controls: minimize · maximize/restore · close -->
            <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Stretch"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinimizeButton"
                        Style="{StaticResource SemaBuzzWinButton}"
                        ToolTip="Minimize"
                        Click="WinBtn_Minimize_Click">
                    <TextBlock Text="&#x2013;" FontSize="14"/>
                </Button>
                <Button x:Name="MaximizeButton"
                        Style="{StaticResource SemaBuzzWinButton}"
                        ToolTip="Maximize"
                        Click="WinBtn_Maximize_Click">
                    <TextBlock x:Name="MaximizeGlyph" Text="&#x25A1;" FontSize="12"/>
                </Button>
                <Button x:Name="CloseButton"
                        Style="{StaticResource SemaBuzzWinButtonClose}"
                        ToolTip="Close"
                        Click="WinBtn_Close_Click">
                    <TextBlock Text="&#x2715;" FontSize="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Trial / license banner (hidden when fully purchased) -->
        <Border x:Name="TrialBanner"
                Grid.Row="2"
                Padding="20 7"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TrialBannerLabel"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           FontStyle="Italic"/>
                <Button x:Name="BuyNowButton"
                        Grid.Column="1"
                        Style="{StaticResource SemaBuzzButton}"
                        Content="BUY NOW"
                        FontSize="11"
                        Padding="10 3"
                        Click="BuyNowButton_Click"/>
            </Grid>
        </Border>

        <!-- Two-pane chat area: local (left) | peer (right) -->
        <Grid Grid.Row="3" Background="{DynamicResource WindowBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Local pane -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="{DynamicResource WindowHeaderBrush}"
                        Padding="14 5">
                    <TextBlock x:Name="LocalPaneLabel"
                               Text="YOU"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AmberBrush}"
                               Opacity="0.7"/>
                </Border>
                <ScrollViewer Grid.Row="1"
                              x:Name="LocalScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14 10">
                    <StackPanel x:Name="LocalPanel" Orientation="Vertical"/>
                </ScrollViewer>
            </Grid>

            <!-- Divider -->
            <Rectangle Grid.Column="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

            <!-- Peer pane -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="{DynamicResource WindowHeaderBrush}"
                        Padding="14 5">
                    <TextBlock x:Name="PeerPaneLabel"
                               Text="PEER"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#9E9E9E"/>
                </Border>
                <ScrollViewer Grid.Row="1"
                              x:Name="PeerScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14 10">
                    <StackPanel x:Name="PeerPanel" Orientation="Vertical"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- BuzzIndicator -->
        <Border Grid.Row="4" Background="{DynamicResource WindowHeaderBrush}" Padding="20 0">
            <controls:SemaBuzzIndicator x:Name="BuzzIndicator"
                                        FilamentBrush="{DynamicResource AmberBrush}"
                                        Height="40"
                                        VerticalAlignment="Center"/>
        </Border>

        <!-- Separator -->
        <Rectangle Grid.Row="5" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Input Row -->
        <Grid Grid.Row="6" Background="{DynamicResource ObsidianSurfaceBrush}">
            <emoji:RichTextBox x:Name="InputBox"
                     Style="{StaticResource SemaBuzzInputRTB}"
                     AcceptsReturn="False"
                     Padding="16 12 132 12"
                     VerticalAlignment="Center"
                     Background="{DynamicResource ObsidianSurfaceBrush}"
                     BorderThickness="0"
                     IsEnabled="False"
                     PreviewKeyDown="InputBox_PreviewKeyDown"
                     TextChanged="InputBox_TextChanged"/>
            <Button x:Name="EmoticonPickerButton"
                    Style="{StaticResource SemaBuzzSendButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="36" Height="36"
                    Margin="0 0 90 0"
                    IsEnabled="{Binding IsEnabled, ElementName=InputBox}"
                    ToolTip="Emoticons"
                    Click="EmoticonPickerButton_Click">
                <Button.ContextMenu>
                    <ContextMenu x:Name="EmoticonMenu"
                                 Placement="Top">

                        <!-- ── Faces ── -->
                        <MenuItem Header="😀  Faces ▶">
                            <MenuItem Tag="🙂" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🙂" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Smile" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😊" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😊" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Blush" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😉" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😉" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Wink" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😂" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😂" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Laugh" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🤣" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🤣" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="ROFL" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😎" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😎" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Cool" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🤔" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🤔" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Thinking" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😏" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😏" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Smirk" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😮" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😮" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Surprised" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😱" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😱" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Screaming" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😢" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😢" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Sad" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😭" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😭" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Crying" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😡" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😡" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Angry" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🤯" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🤯" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Mind blown" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🥳" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🥳" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Party" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🥺" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🥺" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Pleading" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😴" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😴" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Sleeping" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🤒" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🤒" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Sick" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="😈" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="😈" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Devil" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="💀" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="💀" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Skull" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                        </MenuItem>

                        <!-- ── Gestures ── -->
                        <MenuItem Header="👋  Gestures ▶">
                            <MenuItem Tag="👍" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="👍" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Thumbs up" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="👎" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="👎" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Thumbs down" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="👏" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="👏" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Clap" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🙌" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🙌" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Raise hands" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🤝" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🤝" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Handshake" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="✌️" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="✌️" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Peace" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🤞" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🤞" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Fingers crossed" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🤙" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🤙" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Call me" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="👋" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="👋" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Wave" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="💪" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="💪" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Flex" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🙏" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🙏" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Please / Thanks" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🤦" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🤦" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Facepalm" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🤷" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🤷" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Shrug" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                        </MenuItem>

                        <!-- ── Symbols ── -->
                        <MenuItem Header="❤️  Symbols ▶">
                            <MenuItem Tag="❤️" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="❤️" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Heart" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🧡" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🧡" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Orange heart" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="💛" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="💛" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Yellow heart" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="💚" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="💚" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Green heart" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="💙" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="💙" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Blue heart" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="💜" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="💜" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Purple heart" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="💔" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="💔" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Broken heart" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="⭐" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="⭐" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Star" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🔥" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🔥" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Fire" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="✨" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="✨" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Sparkles" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="💥" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="💥" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Boom" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="💤" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="💤" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Zzz" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="💯" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="💯" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="100" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="✅" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="✅" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Check" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="❌" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="❌" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="X" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="❓" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="❓" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Question" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="❗" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="❗" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Exclaim" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                        </MenuItem>

                        <!-- ── Animals & Nature ── -->
                        <MenuItem Header="🐶  Animals &amp; Nature ▶">
                            <MenuItem Tag="🐶" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🐶" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Dog" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🐱" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🐱" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Cat" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🐭" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🐭" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Mouse" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🐺" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🐺" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Wolf" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
                            <MenuItem Tag="🦊" Click="EmoticonButton_Click"><MenuItem.Header><StackPanel Orientation="Horizontal"><emoji:TextBlock Text="🦊" FontSize="16" Margin="0 0 8 0"/><TextBlock Text="Fox" VerticalAlignment="Center"/></StackPanel></MenuItem.Header></MenuItem>
