<Window x:Class="SemaBuzz.App.WhiteboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz — Whiteboard"
        Width="500" Height="430"
        MinWidth="360" MinHeight="300"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource AmberBrush}"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        Topmost="True">

    <Window.Resources>
        <!-- Minimal swatch button: just a colored block with a border that shows selection -->
        <Style x:Key="SwatchStyle" TargetType="Button">
            <Setter Property="Width"             Value="22"/>
            <Setter Property="Height"            Value="22"/>
            <Setter Property="Margin"            Value="0 0 4 0"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="BorderBrush"       Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource WindowHeaderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
              Background="{DynamicResource WindowHeaderBrush}"
              MouseDown="Header_MouseDown">
            <TextBlock Text="WHITEBOARD"
                       FontSize="10" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource AmberBrush}"/>
        </Grid>

        <!-- Sep -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Canvas area -->
        <Border Grid.Row="2" Background="#111214" ClipToBounds="True">
            <Grid>
                <!-- Peer strokes (bottom, hit-test off so mouse events reach local layer) -->
                <Canvas x:Name="PeerCanvas" IsHitTestVisible="False"/>
                <!-- Local strokes (top) -->
                <Canvas x:Name="LocalCanvas"
                        Background="Transparent"
                        Cursor="Cross"
                        MouseDown="Canvas_MouseDown"
                        MouseMove="Canvas_MouseMove"
                        MouseUp="Canvas_MouseUp"
                        MouseLeave="Canvas_MouseLeave"/>
            </Grid>
        </Border>

        <!-- Sep -->
        <Rectangle Grid.Row="3" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Toolbar -->
        <Grid Grid.Row="4" Background="{DynamicResource WindowHeaderBrush}">

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14 0">

                <!-- Color swatches (6): amber · white · red · green · blue · eraser -->
                <Button x:Name="Swatch0" Style="{StaticResource SwatchStyle}"
                        Background="#FFB300" ToolTip="Amber" Click="Swatch_Click"/>
                <Button x:Name="Swatch1" Style="{StaticResource SwatchStyle}"
                        Background="#E0E0E0" ToolTip="White" Click="Swatch_Click"/>
                <Button x:Name="Swatch2" Style="{StaticResource SwatchStyle}"
                        Background="#F44336" ToolTip="Red" Click="Swatch_Click"/>
                <Button x:Name="Swatch3" Style="{StaticResource SwatchStyle}"
                        Background="#4CAF50" ToolTip="Green" Click="Swatch_Click"/>
                <Button x:Name="Swatch4" Style="{StaticResource SwatchStyle}"
                        Background="#2196F3" ToolTip="Blue" Click="Swatch_Click"/>
                <Button x:Name="Swatch5" Style="{StaticResource SwatchStyle}"
                        Background="#616161" ToolTip="Eraser" Click="Swatch_Click"/>

                <!-- Separator -->
                <Rectangle Width="1" Height="20" Fill="{DynamicResource ObsidianBorderBrush}" Margin="8 0"/>

                <!-- Size buttons: thin / medium / thick lines -->
                <Button x:Name="SizeSmall"
                        Style="{StaticResource SemaBuzzButton}"
                        Width="28" Height="28" Margin="0 0 3 0" Padding="4"
                        ToolTip="Thin" Click="SizeBtn_Click">
                    <Rectangle Width="14" Height="2"
                               Fill="{DynamicResource AmberBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button x:Name="SizeMed"
                        Style="{StaticResource SemaBuzzButton}"
                        Width="28" Height="28" Margin="0 0 3 0" Padding="4"
                        ToolTip="Medium" Click="SizeBtn_Click">
                    <Rectangle Width="14" Height="4"
                               Fill="{DynamicResource AmberBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button x:Name="SizeLarge"
                        Style="{StaticResource SemaBuzzButton}"
                        Width="28" Height="28" Margin="0 0 0 0" Padding="4"
                        ToolTip="Thick" Click="SizeBtn_Click">
                    <Rectangle Width="14" Height="8"
                               Fill="{DynamicResource AmberBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Separator -->
                <Rectangle Width="1" Height="20" Fill="{DynamicResource ObsidianBorderBrush}" Margin="8 0"/>

                <!-- Clear -->
                <Button Style="{StaticResource SemaBuzzButton}"
                        Content="CLEAR"
                        Padding="10 4"
                        Click="Clear_Click"/>

            </StackPanel>

            <!-- Close button, right-aligned -->
            <Button Style="{StaticResource SemaBuzzButton}"
                    Content="CLOSE"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Padding="10 4" Margin="0 0 14 0"
                    Click="Close_Click"/>

        </Grid>

        <!-- Resize grip — spans all rows, sits in bottom-right corner -->
        <ResizeGrip Grid.Row="4"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Foreground="{DynamicResource DimTextBrush}"
                    IsTabStop="False"/>

    </Grid>
    </Border>
</Window>
