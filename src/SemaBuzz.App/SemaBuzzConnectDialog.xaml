<Window x:Class="SemaBuzz.App.SemaBuzzConnectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz"
        Width="400"
        SizeToContent="Height"
        Background="{DynamicResource WindowBackgroundBrush}" Foreground="{DynamicResource AmberBrush}"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Window.Resources>
        <!-- Each individual Buzz Code letter cell -->
        <Style x:Key="BuzzCodeBox" TargetType="TextBox">
            <Setter Property="Width"                    Value="46"/>
            <Setter Property="Height"                   Value="58"/>
            <Setter Property="MaxLength"                Value="1"/>
            <Setter Property="FontSize"                 Value="26"/>
            <Setter Property="FontWeight"               Value="Bold"/>
            <Setter Property="Background"               Value="{DynamicResource ObsidianSurfaceBrush}"/>
            <Setter Property="Foreground"               Value="{DynamicResource AmberBrush}"/>
            <Setter Property="CaretBrush"               Value="Transparent"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource AmberDimBrush}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor"                   Value="IBeam"/>
            <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <!-- Pulsing amber glow layer â€” animated when this cell has focus -->
                            <Border x:Name="glow"
                                    Background="{DynamicResource AmberGlowBrush}"
                                    Opacity="0"/>
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AmberBrush}"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="glowAnim">
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation
                                                Storyboard.TargetName="glow"
                                                Storyboard.TargetProperty="Opacity"
                                                From="0.0" To="0.55"
                                                Duration="0:0:0.65"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="glowAnim"/>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="OuterBorder" BorderBrush="{DynamicResource WindowHeaderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowHeaderBrush}"
              MouseLeftButtonDown="Header_MouseDown">
            <TextBlock Text="JOIN A BUZZ"
                       VerticalAlignment="Center" Margin="20 0"
                       Foreground="{DynamicResource AmberHeaderBrush}"
                       FontWeight="Bold" FontSize="13"/>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Content -->
        <StackPanel Grid.Row="2" Margin="0 40 0 40" HorizontalAlignment="Center">

            <!-- JOIN heading -->
            <TextBlock Text="Join a Buzz"
                       FontSize="17" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource AmberBrush}"
                       Margin="0 0 0 26"/>

            <!-- 6-cell Buzz Code input -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBox x:Name="C0" Style="{StaticResource BuzzCodeBox}" Margin="6 0"
                         PreviewTextInput="CodeBox_PreviewTextInput"
                         PreviewKeyDown="CodeBox_PreviewKeyDown"
                         TextChanged="CodeBox_TextChanged"/>
                <TextBox x:Name="C1" Style="{StaticResource BuzzCodeBox}" Margin="6 0"
                         PreviewTextInput="CodeBox_PreviewTextInput"
                         PreviewKeyDown="CodeBox_PreviewKeyDown"
                         TextChanged="CodeBox_TextChanged"/>
                <TextBox x:Name="C2" Style="{StaticResource BuzzCodeBox}" Margin="6 0"
                         PreviewTextInput="CodeBox_PreviewTextInput"
                         PreviewKeyDown="CodeBox_PreviewKeyDown"
                         TextChanged="CodeBox_TextChanged"/>
                <TextBox x:Name="C3" Style="{StaticResource BuzzCodeBox}" Margin="6 0"
                         PreviewTextInput="CodeBox_PreviewTextInput"
                         PreviewKeyDown="CodeBox_PreviewKeyDown"
                         TextChanged="CodeBox_TextChanged"/>
                <TextBox x:Name="C4" Style="{StaticResource BuzzCodeBox}" Margin="6 0"
                         PreviewTextInput="CodeBox_PreviewTextInput"
                         PreviewKeyDown="CodeBox_PreviewKeyDown"
                         TextChanged="CodeBox_TextChanged"/>
                <TextBox x:Name="C5" Style="{StaticResource BuzzCodeBox}" Margin="6 0"
                         PreviewTextInput="CodeBox_PreviewTextInput"
                         PreviewKeyDown="CodeBox_PreviewKeyDown"
                         TextChanged="CodeBox_TextChanged"/>
            </StackPanel>

            <!-- Hint -->
            <TextBlock Text="Enter the buzz code, then press Enter"
                       Foreground="#9E9E9E" FontSize="11"
                       HorizontalAlignment="Center"
                       Margin="0 14 0 0"/>

            <!-- Connect button -->
            <Button x:Name="ConnectBtn"
                    Style="{StaticResource SemaBuzzButton}"
                    Content="JOIN"
                    IsEnabled="False"
                    HorizontalAlignment="Center"
                    MinWidth="200"
                    Padding="0 10"
                    Margin="0 20 0 0"
                    Click="Connect_Click"/>

            <!-- Divider -->
            <Grid Width="300" Margin="0 30 0 30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Rectangle Grid.Column="0" Height="1"
                           Fill="{DynamicResource ObsidianBorderBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="or"
                           Foreground="#9E9E9E" FontSize="11"
                           Margin="14 0"/>
                <Rectangle Grid.Column="2" Height="1"
                           Fill="{DynamicResource ObsidianBorderBrush}"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Start a new buzz -->
            <Button Style="{StaticResource SemaBuzzButton}"
                    Content="START A NEW BUZZ"
                    HorizontalAlignment="Center"
                    MinWidth="200"
                    Padding="0 10"
                    Click="StartBuzz_Click"/>

            <!-- Inline error (e.g. localhost relay warning) -->
            <TextBlock x:Name="ConnectErrorText"
                       Text=""
                       Foreground="#FF5252"
                       FontSize="10"
                       TextWrapping="Wrap"
                       MaxWidth="300"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"
                       Margin="0 14 0 0"/>

        </StackPanel>

        <!-- Separator -->
        <Rectangle Grid.Row="3" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="20 0">
            <Button Style="{StaticResource SemaBuzzButton}" Content="CANCEL"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Click="Cancel_Click"/>
        </Grid>

    </Grid>
    </Border>
</Window>
