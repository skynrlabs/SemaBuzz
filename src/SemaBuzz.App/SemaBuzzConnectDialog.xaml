<Window x:Class="SemaBuzz.App.SemaBuzzConnectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SemaBuzz — Dial the Wire"
        Height="560" Width="420"
        SizeToContent="Height"
        Background="{DynamicResource WindowBackgroundBrush}" Foreground="{DynamicResource AmberBrush}"
        FontFamily="Cascadia Code, JetBrains Mono, Consolas"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowHeaderBrush}"
              MouseLeftButtonDown="Header_MouseDown">
            <TextBlock Text="DIAL THE WIRE"
                       VerticalAlignment="Center" Margin="20 0"
                       FontWeight="Bold" FontSize="13"/>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Content -->
        <StackPanel Grid.Row="2" Margin="24 16">

        <!-- ─── Profile picker ─── -->
        <TextBlock Text="Identity" Foreground="#9E9E9E" FontSize="11" Margin="0 0 0 4"/>
        <Grid Margin="0 0 0 14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="ProfilePicker"
                      Grid.Column="0"
                      Style="{StaticResource SemaBuzzComboBox}"
                      SelectionChanged="ProfilePicker_SelectionChanged"
                      Margin="0 0 6 0"/>
            <Button x:Name="DeleteProfileBtn"
                    Grid.Column="1"
                    Style="{StaticResource SemaBuzzButton}"
                    Content="DELETE"
                    IsEnabled="False"
                    Click="DeleteProfile_Click"/>
        </Grid>

        <!-- Profile card: compact view when a saved profile is active -->
        <Border x:Name="ProfileCard"
                Visibility="Collapsed"
                Background="{DynamicResource ObsidianSurfaceBrush}"
                BorderBrush="{DynamicResource ObsidianBorderBrush}"
                BorderThickness="1"
                Padding="14"
                Margin="0 0 0 16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="CardAvatarEllipse"
                         Width="52" Height="52"
                         Fill="{DynamicResource ObsidianSurfaceBrush}"
                         Stroke="{DynamicResource ObsidianBorderBrush}" StrokeThickness="1"
                         VerticalAlignment="Center"
                         Margin="0 0 14 0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="CardHandleLabel"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource AmberBrush}"/>
                    <TextBlock Text="Saved profile"
                               Foreground="#9E9E9E" FontSize="11"
                               Margin="0 3 0 0"/>
                </StackPanel>
                <Button Grid.Column="2"
                        Content="EDIT"
                        Style="{StaticResource SemaBuzzButton}"
                        VerticalAlignment="Center"
                        Click="EditProfile_Click"/>
            </Grid>
        </Border>

        <!-- Identity fields: shown for new or when editing an existing profile -->
        <StackPanel x:Name="IdentityFields">

            <!-- Handle -->
            <TextBlock Text="Handle" Foreground="#9E9E9E" FontSize="11" Margin="0 0 0 4"/>
            <TextBox x:Name="HandleBox"
                     Style="{StaticResource SemaBuzzInput}"
                     Text="anonymous"
                     Margin="0 0 0 12"/>

            <!-- Avatar -->
            <TextBlock Text="Avatar (optional)" Foreground="#9E9E9E" FontSize="11" Margin="0 0 0 6"/>
            <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                <Ellipse x:Name="AvatarPreview"
                         Width="44" Height="44"
                         Fill="{DynamicResource ObsidianSurfaceBrush}"
                         Stroke="{DynamicResource ObsidianBorderBrush}" StrokeThickness="1"
                         Margin="0 0 10 0"/>
                <StackPanel VerticalAlignment="Center">
                    <Button Style="{StaticResource SemaBuzzButton}"
                            Content="CHOOSE IMAGE"
                            Click="ChooseAvatar_Click"/>
                    <Button x:Name="ClearAvatarBtn"
                            Style="{StaticResource SemaBuzzButton}"
                            Content="CLEAR"
                            IsEnabled="False"
                            Click="ClearAvatar_Click"
                            Margin="0 4 0 0"/>
                </StackPanel>
            </StackPanel>

            <!-- Save this identity as a reusable profile -->
            <Button x:Name="SaveProfileBtn"
                    Style="{StaticResource SemaBuzzButton}"
                    Content="SAVE AS PROFILE"
                    HorizontalAlignment="Left"
                    Margin="0 0 0 16"
                    Click="SaveProfile_Click"/>

        </StackPanel>

        <!-- Mode toggle -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
            <RadioButton x:Name="HostMode" Content="OPEN WIRE" IsChecked="True"
                         GroupName="mode" Margin="0 0 20 0"
                         Checked="ModeChanged"/>
            <RadioButton x:Name="DialMode" Content="DIAL IN"
                         GroupName="mode"
                         Checked="ModeChanged"/>
        </StackPanel>

        <!-- Buzz address (OPEN WIRE mode) — share with your peer -->
        <StackPanel x:Name="HostBuzzPanel" Margin="0 0 0 12">
            <TextBlock Text="Buzz Address — share with your peer"
                       Foreground="#9E9E9E" FontSize="11" Margin="0 0 0 6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="HostBuzzAddressBox"
                         Grid.Column="0"
                         Style="{StaticResource SemaBuzzInput}"
                         IsReadOnly="True"
                         FontSize="16"
                         FontWeight="Bold"
                         Margin="0 0 6 0"/>
                <Button x:Name="CopyHostBuzzBtn"
                        Grid.Column="1"
                        Style="{StaticResource SemaBuzzButton}"
                        Content="COPY"
                        Click="CopyHostBuzz_Click"
                        Margin="0 0 4 0"/>
                <Button Grid.Column="2"
                        Style="{StaticResource SemaBuzzButton}"
                        Content="NEW"
                        Click="NewHostBuzz_Click"/>
            </Grid>
        </StackPanel>

        <!-- Buzz address (DIAL IN mode) -->
        <StackPanel x:Name="BuzzUrlPanel" Visibility="Collapsed" Margin="0 0 0 12">
            <TextBlock Text="Buzz Address" Foreground="#9E9E9E" FontSize="11" Margin="0 0 0 4"/>
            <TextBox x:Name="BuzzUrlBox"
                     Style="{StaticResource SemaBuzzInput}"
                     Text=""/>
        </StackPanel>

        </StackPanel>

        <!-- Separator -->
        <Rectangle Grid.Row="3" Fill="{DynamicResource ObsidianBorderBrush}"/>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="20 0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource SemaBuzzButton}" Content="CANCEL"
                        Margin="0 0 8 0" Click="Cancel_Click"/>
                <Button Style="{StaticResource SemaBuzzButton}" Content="CONNECT"
                        Click="Connect_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
